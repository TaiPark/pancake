generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GroupRole {
  OWNER
  MEMBER
}

enum SessionStage {
  SPARK
  PLAN
  FEEDBACK
}

model User {
  id              String        @id @default(cuid())
  name            String
  email           String        @unique
  passwordHash    String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  groupsOwned     Group[]       @relation("GroupOwner")
  memberships     GroupMember[]
  updatedSessions Session[]     @relation("UpdatedSessions")
  uploadedPhotos  Photo[]       @relation("UploadedPhotos")
}

model Group {
  id         String        @id @default(cuid())
  name       String
  slug       String        @unique
  inviteCode String        @unique
  ownerId    String
  owner      User          @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  members    GroupMember[]
  sessions   Session[]
  llmConfig  LlmConfig?
  skills     LlmSkill[]
}

model GroupMember {
  userId    String
  groupId   String
  role      GroupRole @default(MEMBER)
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
}

model Session {
  id              String       @id @default(cuid())
  groupId         String
  group           Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  title           String
  description     String       @default("")
  skillId         String?
  skill           LlmSkill?    @relation(fields: [skillId], references: [id], onDelete: SetNull)
  stage           SessionStage @default(SPARK)
  expectedShootAt DateTime?
  sparkFields     Json
  planMarkdown    String       @default("")
  aiGenerated     Boolean      @default(false)
  aiRawResponse   String       @default("")
  updatedById     String?
  updatedBy       User?        @relation("UpdatedSessions", fields: [updatedById], references: [id], onDelete: SetNull)
  photos          Photo[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([groupId, stage])
  @@index([skillId])
}

model LlmConfig {
  id          String   @id @default(cuid())
  groupId     String   @unique
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  apiKey      String
  baseUrl     String   @default("https://api.openai.com/v1")
  model       String   @default("gpt-4o")
  temperature Float    @default(0.7)
  maxTokens   Int      @default(4096)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([groupId])
}

model LlmSkill {
  id           String    @id @default(cuid())
  groupId      String
  group        Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name         String
  description  String    @default("")
  systemPrompt String
  fieldHints   Json      @default("{}")
  isDefault    Boolean   @default(false)
  sessions     Session[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([groupId])
}

model Photo {
  id           String   @id @default(cuid())
  sessionId    String
  session      Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  objectKey    String   @unique
  width        Int
  height       Int
  caption      String   @default("")
  uploadedById String
  uploadedBy   User     @relation("UploadedPhotos", fields: [uploadedById], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([sessionId])
}
